<?xml version="1.0" ?>
<!--
  Repo wind-enabled Gazebo world.

  Keep this structurally aligned with `default.sdf` so wind experiments differ
  only by the presence of the world wind vector, not by unrelated world or
  physics configuration changes. The runner rewrites `<linear_velocity>` at
  launch time to match the requested wind condition.
-->
<sdf version="1.6">
  <world name="windy">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <!-- Change plane to box -->
            <box>
              <size>50000 50000 0.1</size> <!-- 10cm thick -->
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>50000 50000 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
        <!-- Offset the link so the top of the box is at Z=0 -->
        <pose>0 0 -0.05 0 0 0</pose>
      </link>
    </model>

    <wind>
      <linear_velocity>0 0 0</linear_velocity>
    </wind>

  </world>
</sdf>
